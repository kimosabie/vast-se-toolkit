# =============================================================
# VAST DATA INSTALLATION - CUMULUS NV CONFIG
# =============================================================
# Cluster:      {{ cluster_name }}
# Customer:     {{ customer }}
# Switch:       {{ hostname }}
# SE:           {{ se_name }}
# Date:         {{ install_date }}
# Generated by: VAST SE Toolkit v1.2.0
# =============================================================
# --- System ---
nv set system hostname {{ hostname }}
nv unset interface eth0 ip address dhcp
nv set interface eth0 ip address {{ mgmt_ip }}
nv set interface eth0 ip gateway {{ mgmt_gw }}
nv set interface eth0 ip vrf mgmt
{# FIELD BUG B — removed: nv set interface eth0 type eth                   #}
{# NVUE rejects this on SN3700 — eth0 type is implicit, do not declare it  #}
{# FIELD BUG C / T1 — removed: nv set interface eth0 vlan {{ mgmt_vlan }}  #}
{# eth0 is in mgmt VRF with a direct IP. It is a UTP port, not a switched  #}
{# port — no VLAN tag is needed or valid here.                              #}
# --- NTP ---
nv unset service ntp default
nv unset service ntp mgmt server 0.cumulusnetworks.pool.ntp.org
nv unset service ntp mgmt server 1.cumulusnetworks.pool.ntp.org
nv unset service ntp mgmt server 2.cumulusnetworks.pool.ntp.org
nv unset service ntp mgmt server 3.cumulusnetworks.pool.ntp.org
nv set service ntp mgmt server {{ ntp_server }} iburst on
# --- QoS for RoCEv2 ---
nv set qos roce
nv set qos pfc-watchdog polling-interval 200
nv set qos pfc-watchdog robustness 5
nv set qos mapping default-global trust l3
# --- Bridge & VLANs ---
nv set bridge domain br_default untagged 10
{# VLAN 69 is VAST internal fabric only — must not appear on the GPU switch  #}
{% if not is_gpu_switch %}
nv set bridge domain br_default vlan 69
{% endif %}
{%- if gpu_vlans is defined and gpu_vlans %}
{% for vid in gpu_vlans %}
nv set bridge domain br_default vlan {{ vid }}
{%- endfor %}
{% endif %}
{# T2 FIX — removed: nv set interface vlan69 vlan 69                       #}
{# removed: nv set interface vlan{{ vid }} vlan {{ vid }} loop              #}
{# This switch is pure L2. Creating SVI interfaces (vlan69, vlan101 etc)   #}
{# implies routed in-band management which is not the design. Management   #}
{# is handled exclusively via eth0 in the mgmt VRF.                        #}
# --- MLAG / Peerlink ---
{% for port in isl_ports -%}
nv set interface peerlink bond member {{ port }}
{% endfor -%}
nv set interface peerlink type peerlink
{# T4 FIX — was hardcoded 44:38:39:ff:00:69 for every switch pair          #}
{# mlag_mac is now generated uniquely per switch pair in app.py             #}
nv set mlag mac-address {{ mlag_mac }}
nv set mlag backup {{ peer_ip }} vrf mgmt
nv set mlag enable on
nv set mlag peer-ip linklocal
# --- ISL Port Types ---
{% for port in isl_ports -%}
nv set interface {{ port }} type swp
nv set interface {{ port }} link mtu 9216
{% endfor %}
{# T6 FIX — uplink comment moved inside the if block so it is fully        #}
{# suppressed when no uplink ports are configured (storage switch)          #}
{% if uplink_ports %}
# --- Customer Uplink (MLAG LACP) ---
{% for port in uplink_ports -%}
nv set interface uplink bond member {{ port }}
{% endfor -%}
nv set interface uplink bond mlag id {{ clag_id }}
nv set interface uplink bridge domain br_default
nv set interface uplink link mtu 9216
nv set interface uplink type bond
nv set interface uplink description "Uplink-to-{{ uplink_description }}"
{% endif %}
# --- Node Ports ---
{% for item in port_map -%}
nv set interface {{ item.swp }} bridge domain br_default
nv set interface {{ item.swp }} link mtu 9216
nv set interface {{ item.swp }} qos pfc-watchdog
nv set interface {{ item.swp }} type swp
nv set interface {{ item.swp }} description "{{ item.desc }}"
{% endfor %}
nv config apply -y
nv config save
