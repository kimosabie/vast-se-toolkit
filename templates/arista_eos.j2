! =============================================================
! VAST DATA INSTALLATION - ARISTA EOS CONFIG
! =============================================================
! Cluster:      {{ cluster_name }}
! Customer:     {{ customer }}
! Switch:       {{ hostname }}
! SE:           {{ se_name }}
! Date:         {{ install_date }}
! Generated by: VAST SE Toolkit v1.2.0
! =============================================================

hostname {{ hostname }}

! --- NTP ---
ntp server vrf mgmt {{ ntp_server }} prefer

! --- VLANs ---
vlan 69
   name VAST-Internal
!
{% if gpu_vlans is defined and gpu_vlans %}
{% for vid in gpu_vlans %}
vlan {{ vid }}
   name GPU-Client-{{ vid }}
!
{% endfor %}
{% endif %}
vlan 4094
   name MLAG-Peer
   trunk group MLAG-Peer
!

! --- QoS for RoCEv2 ---
dcbx app priority-tagged ports all
qos map dscp-to-traffic-class 26 to 3
priority-flow-control mode on
!

! --- MLAG Peerlink ---
interface Port-Channel999
   description ISL-Peerlink
   switchport mode trunk
   spanning-tree link-type point-to-point
!
{% for port in isl_ports %}
interface {{ port | replace('swp', 'Ethernet') }}
   description ISL-Peerlink-Member
   channel-group 999 mode active
   mtu {{ mtu }}
   no shutdown
!
{% endfor %}

! --- MLAG Peer VLAN ---
interface Vlan4094
   description MLAG-Peer-Link
   no autostate
   ip address {{ '169.254.0.1' if mgmt_ip.split('.')[3].split('/')[0] | int < peer_ip.split('.')[3] | int else '169.254.0.2' }}/30
!

! --- MLAG Configuration ---
mlag configuration
   domain-id {{ cluster_name }}-MLAG
   local-interface Vlan4094
   peer-address heartbeat {{ peer_ip }} vrf mgmt
   peer-link Port-Channel999
   reload-delay mlag 300
   reload-delay non-mlag 330
!

! --- Customer Uplink (MLAG LACP) ---
interface Port-Channel{{ clag_id }}
   description Uplink-to-Customer-Core
   switchport mode trunk
   mtu {{ mtu }}
   mlag {{ clag_id }}
!
{% for port in uplink_ports %}
interface {{ port | replace('swp', 'Ethernet') }}
   description Uplink-Member
   channel-group {{ clag_id }} mode active
   mtu {{ mtu }}
   no shutdown
!
{% endfor %}

! --- Node Ports ---
{% for item in port_map %}
interface {{ item.eth }}
   description {{ item.desc }}
{% if gpu_vlans is defined and gpu_vlans | length > 1 %}
   switchport mode trunk
   switchport trunk allowed vlan {{ gpu_vlans | join(',') }}
{% else %}
   switchport access vlan {{ gpu_vlans[0] if gpu_vlans else vlan_id }}
{% endif %}
   mtu {{ mtu }}
   spanning-tree portfast
   no shutdown
!
{% endfor %}

! --- Management Interface ---
interface Management1
   encapsulation dot1q vlan {{ mgmt_vlan }}
   ip address {{ mgmt_ip }}
   no shutdown
!
ip route vrf mgmt 0.0.0.0/0 {{ mgmt_gw }}

! --- Management API ---
management api http-commands
   protocol https
   no shutdown
!
