# VAST SE Toolkit — environment configuration
#
# Cloud Backup (Google Drive)
# Set CLOUD_SYNC_DIR to your local Google Drive sync folder path, then restart the app.
#
# Windows (WSL2) example:
#   CLOUD_SYNC_DIR=/mnt/c/Users/yourname/Google Drive/My Drive/VAST Backups
#
# macOS example:
#   CLOUD_SYNC_DIR=/Users/yourname/Library/CloudStorage/GoogleDrive-you@email.com/My Drive/VAST Backups
#
# CLOUD_SYNC_DIR=

# Cloud AI — Technical Expert mode (optional)
# Keys can also be entered directly in the AI Assistant tab UI.
# CLAUDE_API_KEY=    # console.anthropic.com
# OPENAI_API_KEY=    # platform.openai.com
# GEMINI_API_KEY=    # aistudio.google.com
